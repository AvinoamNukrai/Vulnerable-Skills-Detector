{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill Scanning Crawler Output Schemas",
  "$defs": {
    "RepositoryRecord": {
      "type": "object",
      "required": [
        "repository_id",
        "platform",
        "owner",
        "name",
        "full_name",
        "url",
        "stars",
        "forks",
        "is_fork",
        "is_archived",
        "default_branch",
        "commit_sha",
        "discovery_sources",
        "skill_count",
        "selected_for_export",
        "collected_at"
      ],
      "properties": {
        "repository_id": {
          "type": "string"
        },
        "platform": {
          "const": "github"
        },
        "owner": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "full_name": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "stars": {
          "type": "integer",
          "minimum": 0
        },
        "forks": {
          "type": "integer",
          "minimum": 0
        },
        "is_fork": {
          "type": "boolean"
        },
        "is_archived": {
          "type": "boolean"
        },
        "default_branch": {
          "type": "string"
        },
        "commit_sha": {
          "type": "string"
        },
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repository_size_kb": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "discovery_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "discovery_queries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skill_count": {
          "type": "integer",
          "minimum": 0
        },
        "selected_for_export": {
          "type": "boolean"
        },
        "collected_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "SkillRecord": {
      "type": "object",
      "required": [
        "skill_id",
        "repository_id",
        "platform",
        "owner",
        "repo",
        "repository_url",
        "skill_path",
        "skill_name",
        "validation_status",
        "commit_sha",
        "content_hash",
        "file_count",
        "total_size_bytes",
        "files",
        "snapshot_path",
        "snapshot_complete",
        "excluded_files",
        "collected_at"
      ],
      "properties": {
        "skill_id": {
          "type": "string"
        },
        "repository_id": {
          "type": "string"
        },
        "platform": {
          "const": "github"
        },
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "repository_url": {
          "type": "string"
        },
        "skill_path": {
          "type": "string"
        },
        "skill_name": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "validation_status": {
          "enum": [
            "valid_standard",
            "valid_lenient"
          ]
        },
        "commit_sha": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "snapshot_path": {
          "type": "string"
        },
        "snapshot_complete": {
          "type": "boolean"
        },
        "excluded_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "reason"],
            "properties": {
              "path": { "type": "string" },
              "reason": {
                "type": "string",
                "enum": ["binary", "oversized", "unsafe_path", "download_failed"]
              }
            },
            "additionalProperties": false
          }
        },
        "collected_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "RejectedCandidateRecord": {
      "type": "object",
      "required": [
        "candidate_id",
        "repository_id",
        "platform",
        "owner",
        "repo",
        "path",
        "rejection_status",
        "rejection_reason",
        "discovery_sources",
        "collected_at"
      ],
      "properties": {
        "candidate_id": {
          "type": "string"
        },
        "repository_id": {
          "type": "string"
        },
        "platform": {
          "const": "github"
        },
        "owner": {
          "type": "string"
        },
        "repo": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "rejection_status": {
          "enum": [
            "invalid_missing_skill_md",
            "invalid_missing_frontmatter",
            "invalid_malformed_frontmatter",
            "invalid_missing_name",
            "invalid_missing_description",
            "documentation_only",
            "example_only",
            "too_large",
            "binary_or_unsupported",
            "repository_unavailable",
            "undetermined"
          ]
        },
        "rejection_reason": {
          "type": "string"
        },
        "discovery_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "discovery_queries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commit_sha": {
          "type": [
            "string",
            "null"
          ]
        },
        "collected_at": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}